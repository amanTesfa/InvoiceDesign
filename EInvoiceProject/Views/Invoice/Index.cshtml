@model EnvoiceProject.Models.EnvoiceDTO
<!-- Bootstrap 5 CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"
      crossorigin="anonymous">
      <link href="~/css/site.css" rel="stylesheet" />

<style>
    .dx-datagrid .dx-row>td,
    .dx-datagrid .dx-row>tr>td {
        padding: 2px 7px !important;
        border-bottom: 1px solid #dadada;
    }
    .text-danger {
        color: #ff0019 !important;
        font-weight: bold;
    }
    .btn-danger {
  color: red;
  padding: 0 15px;
  border-radius: 4px;
}
    .dx-toast-warning{
        width: 60vw !important;
    }
    th{
        background: #e5e5e9 !important;
    }
      .dx-freespace-row {
        display: none !important
    }

    .dx-header-row td {
        background-color: #e3e3e3 !important;
        color: black;
    }

    .dx-footer-row td {
        background-color: #e3e3e3 !important;
        color: black;
    }

    .dx-dialog-message {
        color: #ff0000;
    }

    .dx-datagrid .dx-row > td, .dx-datagrid .dx-row > tr > td {
        padding: 3px !important;
    }
    .bg-green{
        background: #bcddda;
    }
    .text-green{
        color: #009688;
    }
</style>
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12 col-md-11">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-1">
                        <h4 class="fw-bold text-green mb-1">Invoice Preparation</h4>
                    </div>
                    @using (Html.BeginForm("Create", "Invoice", FormMethod.Post))
                    {
                        <div class="row">
                            <div class="d-flex justify-content-end mb-4 gap-2">
                                <button type="submit" class="btn-invoice "
                                        style="padding:4px 20px;border-radius:4px">Submit</button>
                                <button type="reset" class="btn-invoice "
                                        style="padding:4px 20px;border-radius:4px">Clear</button>
                            </div>
                            <!-- Left Section: Supplier/Item Details -->
                            <div class="col-md-8">
                                <div class="card mb-3">
                                    <div class="card-header bg-green bg-opacity-25 fw-bold">Invoice Data</div>
                                    <div class="card-body p-3">
                                        <div class="row mb-2">
                                            <div class="col-md-2">
                                                <label class="form-label">Client</label>
                                            </div>
                                            <div class="col-md-8">
                                                <!-- Hidden field to bind selected customer id -->
                                                <input type="hidden" name="customer.customerId" id="customerId" />
                                                <!-- DevExtreme SelectBox placeholder -->
                                                <div id="customerSelectBox"></div>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-2">
                                                <label class="form-label">Invoice Type</label>
                                            </div>
                                            <div class="col-md-8">
                                                <select id="voucherType" name="voucher.voucherType"
                                                        class="form-select form-select-sm">
                                                    <option value="Cash Invoice">Cash Invoice</option>
                                                    <option value="Credit Invoice">Credit Invoice</option>
                                                    <option value="Debit Invoice">Debit Invoice</option>
                                                    <option value="Proforma Invoice">Proforma Invoice</option>
                                                    <option value="Refund Invoice">Refund Invoice</option>
                                                    <option value="General Invoice">General Invoice</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-2">
                                                <label class="form-label">Item <span
                                                    class="text-danger">*</span></label>
                                                </div>
                                                <div class="col-md-8">
                                                    <!-- hidden field to bind selected article id -->
                                                    <input type="hidden" id="ArticleId" name="ArticleId" />
                                                    <div id="itemSelectBox"></div>
                                                </div>
                                                <div class="col-md-2">
                                                    <button id="AddItemButton" type="button" class="btn-invoice-small"
                                                            style="padding:3px 10px;border-radius:4px">Add Item</button>
                                                </div>
                                            </div>
                                            <div class="row mb-2">
                                                <div class="col-md-2">
                                                    <label class="form-label">Qty <span class="text-danger">*</span></label>
                                                </div>
                                                <div class="col-md-4">

                                                    <input id="qty" name="qty" type="number" step="0.01"
                                                           class="form-control form-control-sm"  />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label">Price <span
                                                        class="text-danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <input id="price" name="price" type="number" step="0.01"
                                                               class="form-control form-control-sm"  />
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                        <div class="card mb-3">
                                            <div class="card-header bg-green bg-opacity-25 fw-bold">Line Items</div>
                                            <div class="card-body p-2">
                                                <table style="width:100%" id="lineitemTable"
                                                       class="table table-bordered table-sm">
                                                    <thead class="bg-green bg-opacity-25">
                                                        <tr>
                                                            <th>Item Code</th>
                                                    <th>Item Name</th>
                                                            <th style="text-align:right">Quantity</th>
                                                            <th style="text-align:right">Price</th>
                                                            <th style="text-align:right">Total</th>
                                                            <th style="width:50px"></th> <!-- remove button -->
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                             
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Right Section: Voucher Info & Summary -->
                                    <div class="col-md-4">
                                        <div class="card mb-3">
                                    <div class="card-header bg-green bg-opacity-25 fw-bold">Invoice Info</div>
                                            <div class="card-body p-3">
                                                <div class="mb-2 row align-items-center">
                                                    <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">
                                                    Invoice No <span class="text-danger">*</span></label>
                                                        </div>
                                                        <div class="col-7 col-md-7">
                                                            <input id="voucherNumber" name="voucher.voucherNumber" class="form-control form-control-sm" placeholder="Number" />
                                                        </div>
                                                    </div>
                                                    <div class="mb-2 row align-items-center">
                                                        <div class="col-5 col-md-5">
                                                            <label class="form-label mb-0">Date</label>
                                                        </div>
                                                        <div class="col-7 col-md-7">
                                                            <input id="voucherDate" name="voucher.voucherDate" type="date" value="@DateTime.Now.ToString("yyy-MM-dd")" class="form-control form-control-sm" />
                                                        </div>
                                                    </div>
                                                    <div class="mb-2 row align-items-center">
                                                        <div class="col-5 col-md-5">
                                                            <label class="form-label mb-0">Reference</label>
                                                        </div>
                                                        <div class="col-7 col-md-7">
                                                            <input id="voucherReference" name="voucher.voucherReference" class="form-control form-control-sm" placeholder="Reference" />
                                                        </div>
                                                    </div>
                                                    <div class="mb-2 row align-items-center">
                                                        <div class="col-5 col-md-5">
                                                            <label class="form-label mb-0">Remark</label>
                                                        </div>
                                                        <div class="col-7 col-md-7">
                                                            <input id="voucherRemark" name="voucher.voucherRemark" type="text" class="form-control form-control-sm" placeholder="Remark" />
                                                        </div>
                                                    </div>
                                                    <div class="mb-2 row align-items-center">
                                                        <div class="col-5 col-md-5">
                                                            <label class="form-label mb-0">Payment Info</label>
                                                        </div>
                                                        <div class="col-7 col-md-7">
                                                <select id="voucherPaymentInfo" name="voucher.voucherPaymentInfo" class="form-select form-select-sm">
                                                    <option value="Cash">Cash</option>
                                                    <option value="Bank Tranfer">Bank Tranfer</option>
                                                    <option value="Cheque">Cheque</option>
                                                    <option value="Card">Card</option>
                                                </select>
                                                       </div>
                                                    </div>
                                                    <div class="mb-2 row align-items-center">
                                                        <div class="col-5 col-md-5">
                                                            <label class="form-label mb-0">User</label>
                                                        </div>
                                                        <div class="col-7 col-md-7">
                                                <select id="voucher.voucherPreparedBy" name="voucher.voucherPreparedBy" class="form-select form-select-sm">
                                                                <option value="Abel Abraham">Abel Abraham</option>
                                                                <option value="Admin">Admin</option>
                                                                <option value="Simon Tolu">Simon Tolu</option>
                                                                <option value="liya Adam">liya Adam</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card mb-3">
                                                <div class="card-header bg-green bg-opacity-25 fw-bold">Summary</div>
                                                <div class="card-body p-3">
                                                    <div class="row mb-2 align-items-center">
                                                        <div class="col-6">
                                                            <label class="form-label">Subtotal</label>
                                                        </div>
                                                        <div class="col-6">
                                                <input id="voucherSubtotal" name="voucher.voucherSubtotal" readonly style="width:100%" type="number" class="form-control form-control-sm bg-green bg-opacity-25 text-end" value="0.00" />
                                                        </div>
                                                    </div>
                                                    <div class="row mb-2 align-items-center">
                                                        <div class="col-6">
                                                            <label class="form-label">Tax(15%)</label>
                                                        </div>
                                                        <div class="col-6">
                                                <input id="voucherTax" name="voucher.voucherTax" readonly style="width:100%" type="number" class="form-control form-control-sm bg-green bg-opacity-25 text-end" value="0.00" />
                                                        </div>
                                                    </div>
                                                    <div class="row mb-2 align-items-center">
                                                        <div class="col-6">
                                                            <label class="form-label">Additional Charge(2%)</label>
                                                        </div>
                                                        <div class="col-6">
                                                <input id="voucherAdditionalCharge" name="voucher.voucherAdditionalCharge" readonly style="width:100%" type="number"  class="form-control form-control-sm bg-green bg-opacity-25 text-end" value="0.00" />
                                                        </div>
                                                    </div>
                                                    <div class="row mb-2 align-items-center">
                                                        <div class="col-6">
                                                            <label class="form-label">Grand Total</label>
                                                        </div>
                                                        <div class="col-6">
                                                <input id="voucherGrandTotal" name="voucher.voucherGrandTotal" readonly type="number" style="width:100%" class="form-control form-control-sm bg-green bg-opacity-25 text-end" value="0.00" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                    </div>
                    }
                    </div>
                    </div>
                    </div>
                    </div>
                    
                </div>

                <script type="text/javascript">
                    var customerStore = new DevExpress.data.ArrayStore({
                    key: 'customerId',
                    data: []
                    });
                    var customerDataSource = new DevExpress.data.DataSource({ store: customerStore });
                    // load customer data into store
                    $.getJSON('@Url.Action("GetCustomer","Invoice")').done(function (result) {
                    customerStore.push(result.map(function (item) { return { type: 'insert', data: item }; }));
                    });

                    // fetch items list and create store
                    var itemStore = new DevExpress.data.ArrayStore({
                    key: 'articleId',
                    data: []
                    });
                    var itemDataSource = new DevExpress.data.DataSource({ store: itemStore });
                    $.getJSON('@Url.Action("GetItems","Invoice")').done(function (result) {
                    itemStore.push(result.map(function (i) { return { type: 'insert', data: i }; }));
                    });

                    $("#customerSelectBox").dxDropDownBox({
                    valueExpr: 'customerId',
                    displayExpr: function (item) {
                    if (!item) return '';
                    return item.customerName + ' (' + item.customerTinNo + ')';
                    },
                    dataSource: customerDataSource,
                    placeholder: 'Select Client...',
                    contentTemplate: function (e) {
                    var $dataGrid = $("<div>")
                    .dxDataGrid({
                    dataSource: customerDataSource,
                    columns: [
                    { dataField: 'customerName', caption: 'Customer' },
                    { dataField: 'customerTinNo', caption: 'TIN' }
                    ],
                    hoverStateEnabled: true,
                    selection: { mode: 'single' },
                    height: 200,
                    onSelectionChanged: function (args) {
                    var selectedKey = args.selectedRowKeys[0];
                    e.component.option('value', selectedKey);
                        $("#customerId").val(selectedKey);
                    e.component.close();
                    }
                    });
                    return $dataGrid;
                    }
                    });
                    $("#itemSelectBox").dxDropDownBox({
                    valueExpr: 'articleId',
                    displayExpr: function (item) {
                    if (!item) return '';
                    return item.articleCode + ' - ' + item.articleName + ' (' + item.unit + ')';
                    },
                    dataSource: itemDataSource,
                    placeholder: 'Select item...',
                    contentTemplate: function (e) {
                    var $grid = $("<div>")
                    .dxDataGrid({
                    dataSource: itemDataSource,
                    columns: [
                    { dataField: 'articleCode', caption: 'Code' },
                    { dataField: 'articleName', caption: 'Name' },
                    { dataField: 'unit', caption: 'Unit' }
                    ],
                    hoverStateEnabled: true,
                    selection: { mode: 'single' },
                    height: 200,
                    onSelectionChanged: function (args) {
                    var key = args.selectedRowKeys[0];
                    e.component.option('value', key);
                    $("#ArticleId").val(key);
                    e.component.close();
                    }
                    });
                    return $grid;
                    }
                    });
                    
                    // utility to recalculate summary fields from current line items
                    function recalcSummary() {
                        var subtotal = 0;
                        $('#lineitemTable tbody tr').each(function () {
                            var t = parseFloat($(this).find('td').eq(4).text()) || 0;
                            subtotal += t;
                        });
                        var tax = subtotal * 0.15;
                        var add = subtotal * 0.02;
                        var grand = subtotal + tax + add;
                        $("#voucherSubtotal").val(subtotal.toFixed(2));
                        $("#voucherTax").val(tax.toFixed(2));
                        $("#voucherAdditionalCharge").val(add.toFixed(2));
                        $("#voucherGrandTotal").val(grand.toFixed(2));
                        console.log('recalcSummary called, subtotal=', subtotal, 'tax=', tax, 'add=', add, 'grand=', grand);
                    }
                    var lineIndex = 0;
                    $('form').on('reset', function(){
                        setTimeout(recalcSummary, 0);
                    });
                    var tbodyEl = document.querySelector('#lineitemTable tbody');
                    if (tbodyEl) {
                        new MutationObserver(function(){ recalcSummary(); }).observe(tbodyEl, { childList: true });
                    }
                    $('#lineitemTable').on('click', '.removeLine', function(){
                        $(this).closest('tr').remove();
                        recalcSummary();
                    });

                    $("#AddItemButton").click(function(e){
                        e.preventDefault();
                        var qty = parseFloat($("input[name='qty']").val()) || 0;
                        var price = parseFloat($("input[name='price']").val()) || 0;
                        var articleId = $("#ArticleId").val();
                        if(!articleId || qty <= 0 || price <= 0){
            DevExpress.ui.dialog.alert("Please select item and enter valid quantity & price", "Invoice");
                            return;
                        }
                        if($('#lineitemTable tbody tr[data-articleid="'+articleId+'"]').length){
            DevExpress.ui.dialog.alert("Item already added", "Invoice");
                            return;
                        }
                        $.ajax({
                            url: '@Url.Action("AddLineItem","Invoice")',
                            type: 'POST',
                            data: { articleId: articleId, qty: qty, price: price },
                            success: function(data){
                                var idx = lineIndex++;
                                var row = '<tr data-articleid="'+data.articleId+'">' +
                                          '<td>' + data.articleCode + '</td>' +
                                          '<td>' + data.articleName + '</td>' +
                                          '<td style="text-align:right">' + data.qty + '</td>' +
                                          '<td style="text-align:right">' + data.price + '</td>' +
                                          '<td style="text-align:right">' + data.total + '</td>' +
                                          '<td><button type="button" class="removeLine  btn-sm btn-danger">&times;</button></td>' +
                                          '<td style="display:none">' +
                                            '<input type="hidden" name="itemList['+idx+'].articleId" value="'+data.articleId+'" />' +
                                            '<input type="hidden" name="itemList['+idx+'].qty" value="'+data.qty+'" />' +
                                            '<input type="hidden" name="itemList['+idx+'].price" value="'+data.price+'" />' +
                                            '<input type="hidden" name="itemList['+idx+'].total" value="'+data.total+'" />' +
                                          '</td>' +
                                          '</tr>';
                                $('#lineitemTable tbody').append(row);
                                recalcSummary();
                                $("#ArticleId").val('');
                                $('#itemSelectBox').dxDropDownBox('instance').option('value', null);
                                $("input[name='qty'], input[name='price']").val('');
                            },
                            error: function(xhr){
                DevExpress.ui.dialog.alert("Error adding item", "Invoice");
            }
                        });
                    });
                    recalcSummary();
                    console.log('summary recalculated on load');

                    // client-side validation before final submit
                    $('form').on('submit', function(e){
                        var vouc = $('#voucherNumber').val();
                        var vnum = $('input[name="voucher.voucherNumber"]').val();
                        var lines = $('#lineitemTable tbody tr').length;
                        if(!vouc){
            DevExpress.ui.dialog.alert("Please enter voucher number", "Invoice");
                            e.preventDefault();
                            return false;
                        }
                        if(!vnum){
            DevExpress.ui.dialog.alert("Please enter voucher number", "Invoice");
                            e.preventDefault();
                            return false;
                        }
                        if(lines===0){
            DevExpress.ui.dialog.alert("Please add at least one line item", "Invoice");

                            e.preventDefault();
                            return false;
                        }
                    });
                </script>
            